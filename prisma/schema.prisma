// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  OWNER
  MANAGER
  DRIVER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum SafetyEventType {
  HARSH_BRAKING
  HARSH_ACCELERATION
  HARSH_CORNERING
  SPEEDING
  DISTRACTED_DRIVING
  ROLLING_STOP
  SEATBELT_VIOLATION
  FOLLOWING_TOO_CLOSE
}

enum SafetyEventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FuelType {
  DIESEL
  GASOLINE
  ELECTRIC
  HYBRID
  CNG
  LPG
}

enum PaymentStatus {
  PENDING
  PAID
}

// Models
model Tenant {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  slug                  String?  @unique
  timezone              String   @default("UTC")
  isActive              Boolean  @default(true)
  profitMarginThreshold Decimal  @default(10) @db.Decimal(5, 2)
  createdAt             DateTime @default(now()) @db.Timestamptz
  updatedAt             DateTime @updatedAt @db.Timestamptz

  users              User[]
  trucks             Truck[]
  driverInvitations  DriverInvitation[]
  routes             Route[]
  documents          Document[]
  maintenanceEvents  MaintenanceEvent[]
  scheduledServices  ScheduledService[]
  notificationLogs   NotificationLog[]
  gpsLocations       GPSLocation[]
  safetyEvents       SafetyEvent[]
  fuelRecords        FuelRecord[]
  tags               Tag[]
  tagAssignments     TagAssignment[]
  expenseCategories  ExpenseCategory[]
  expenseTemplates   ExpenseTemplate[]
  routeExpenses      RouteExpense[]
  routePayments      RoutePayment[]
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  clerkUserId   String   @unique
  email         String
  role          UserRole
  isSystemAdmin Boolean  @default(false)
  firstName     String?
  lastName      String?
  licenseNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  assignedRoutes    Route[]
  uploadedDocuments Document[]
  safetyEvents      SafetyEvent[]
  tagAssignments    TagAssignment[]

  @@index([tenantId])
  @@index([clerkUserId])
  @@index([email])
}

model Truck {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  make              String
  model             String
  year              Int
  vin               String
  licensePlate      String
  odometer          Int      // Whole miles only (federal requirement)
  documentMetadata  Json?    // JSONB: registration number, insurance expiry, etc.
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  assignedRoutes     Route[]
  documents          Document[]
  maintenanceEvents  MaintenanceEvent[]
  scheduledServices  ScheduledService[]
  gpsLocations       GPSLocation[]
  safetyEvents       SafetyEvent[]
  fuelRecords        FuelRecord[]
  tagAssignments     TagAssignment[]

  @@unique([tenantId, vin])
  @@index([tenantId])
}

model DriverInvitation {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @db.Uuid
  email              String
  firstName          String
  lastName           String
  licenseNumber      String?
  clerkInvitationId  String           @unique
  expiresAt          DateTime         @db.Timestamptz
  status             InvitationStatus @default(PENDING)
  acceptedAt         DateTime?        @db.Timestamptz
  userId             String?          @db.Uuid
  createdAt          DateTime         @default(now()) @db.Timestamptz
  updatedAt          DateTime         @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([clerkInvitationId])
}

model Route {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String      @db.Uuid
  driverId       String      @db.Uuid
  truckId        String      @db.Uuid
  origin         String
  destination    String
  scheduledDate  DateTime    @db.Timestamptz
  status         RouteStatus @default(PLANNED)
  notes          String?
  completedAt    DateTime?   @db.Timestamptz
  version        Int         @default(1)
  startOdometer  Int?
  endOdometer    Int?
  createdAt      DateTime    @default(now()) @db.Timestamptz
  updatedAt      DateTime    @updatedAt @db.Timestamptz

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  driver       User           @relation(fields: [driverId], references: [id])
  truck        Truck          @relation(fields: [truckId], references: [id])
  documents    Document[]
  safetyEvents SafetyEvent[]
  expenses     RouteExpense[]
  payments     RoutePayment[]

  @@index([tenantId])
  @@index([driverId])
  @@index([truckId])
  @@index([scheduledDate])
  @@index([status])
}

model Document {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  truckId     String?  @db.Uuid
  routeId     String?  @db.Uuid
  fileName    String
  s3Key       String
  contentType String
  sizeBytes   Int
  uploadedBy  String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  truck    Truck?  @relation(fields: [truckId], references: [id])
  route    Route?  @relation(fields: [routeId], references: [id])
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([routeId])
  @@index([uploadedBy])
}

model MaintenanceEvent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  truckId           String   @db.Uuid
  serviceType       String
  serviceDate       DateTime @db.Timestamptz
  odometerAtService Int
  cost              Decimal? @db.Decimal(10, 2)
  provider          String?
  notes             String?
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([serviceDate])
}

model ScheduledService {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  truckId          String    @db.Uuid
  serviceType      String
  intervalDays     Int?
  intervalMiles    Int?
  baselineDate     DateTime  @db.Timestamptz
  baselineOdometer Int
  notes            String?
  isCompleted      Boolean   @default(false)
  completedAt      DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([isCompleted])
}

model NotificationLog {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String             @db.Uuid
  idempotencyKey  String             @unique
  notificationType String
  entityType      String?
  entityId        String?            @db.Uuid
  recipientEmail  String
  status          NotificationStatus @default(PENDING)
  sentAt          DateTime?          @db.Timestamptz
  failedAt        DateTime?          @db.Timestamptz
  errorMessage    String?
  retryCount      Int                @default(0)
  emailSubject    String?
  externalId      String?
  createdAt       DateTime           @default(now()) @db.Timestamptz
  updatedAt       DateTime           @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([idempotencyKey])
  @@index([createdAt])
}

model GPSLocation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  truckId   String   @db.Uuid
  latitude  Decimal  @db.Decimal(10, 8)
  longitude Decimal  @db.Decimal(11, 8)
  speed     Int?
  heading   Int?
  altitude  Int?
  accuracy  Decimal? @db.Decimal(6, 2)
  timestamp DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([timestamp])
  @@index([tenantId, timestamp])
}

model SafetyEvent {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String              @db.Uuid
  truckId    String              @db.Uuid
  driverId   String?             @db.Uuid
  routeId    String?             @db.Uuid
  eventType  SafetyEventType
  severity   SafetyEventSeverity
  gForce     Decimal?            @db.Decimal(4, 2)
  speed      Int?
  speedLimit Int?
  latitude   Decimal             @db.Decimal(10, 8)
  longitude  Decimal             @db.Decimal(11, 8)
  timestamp  DateTime            @db.Timestamptz
  metadata   Json?
  createdAt  DateTime            @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])
  driver User?  @relation(fields: [driverId], references: [id])
  route  Route? @relation(fields: [routeId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([driverId])
  @@index([routeId])
  @@index([eventType])
  @@index([severity])
  @@index([timestamp])
  @@index([tenantId, timestamp])
}

model FuelRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  truckId     String   @db.Uuid
  fuelType    FuelType
  quantity    Decimal  @db.Decimal(10, 2)
  unitCost    Decimal? @db.Decimal(10, 4)
  totalCost   Decimal? @db.Decimal(10, 2)
  odometer    Int
  location    String?
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  timestamp   DateTime @db.Timestamptz
  isEstimated Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([timestamp])
  @@index([tenantId, timestamp])
  @@index([isEstimated])
}

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  assignments TagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TagAssignment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  tagId     String   @db.Uuid
  truckId   String?  @db.Uuid
  userId    String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  truck  Truck? @relation(fields: [truckId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tagId, truckId])
  @@unique([tagId, userId])
  @@index([tenantId])
  @@index([tagId])
  @@index([truckId])
  @@index([userId])
}

model ExpenseCategory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  name            String
  isSystemDefault Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  expenses      RouteExpense[]
  templateItems ExpenseTemplateItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model RouteExpense {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  routeId     String    @db.Uuid
  categoryId  String    @db.Uuid
  amount      Decimal   @db.Decimal(10, 2)
  description String
  notes       String?
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  route    Route           @relation(fields: [routeId], references: [id])
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
  @@index([routeId])
  @@index([categoryId])
  @@index([deletedAt])
}

model ExpenseTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  items  ExpenseTemplateItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ExpenseTemplateItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String  @db.Uuid
  categoryId  String  @db.Uuid
  amount      Decimal @db.Decimal(10, 2)
  description String

  template ExpenseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([templateId])
  @@index([categoryId])
}

model RoutePayment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String        @db.Uuid
  routeId   String        @db.Uuid
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?     @db.Timestamptz
  notes     String?
  deletedAt DateTime?     @db.Timestamptz
  createdAt DateTime      @default(now()) @db.Timestamptz
  updatedAt DateTime      @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  route  Route  @relation(fields: [routeId], references: [id])

  @@index([tenantId])
  @@index([routeId])
  @@index([status])
  @@index([deletedAt])
}
