// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  OWNER
  MANAGER
  DRIVER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

// Models
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String?  @unique
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  users              User[]
  trucks             Truck[]
  driverInvitations  DriverInvitation[]
  routes             Route[]
  documents          Document[]
  maintenanceEvents  MaintenanceEvent[]
  scheduledServices  ScheduledService[]
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  clerkUserId   String   @unique
  email         String
  role          UserRole
  isSystemAdmin Boolean  @default(false)
  firstName     String?
  lastName      String?
  licenseNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  tenant            Tenant     @relation(fields: [tenantId], references: [id])
  assignedRoutes    Route[]
  uploadedDocuments Document[]

  @@index([tenantId])
  @@index([clerkUserId])
  @@index([email])
}

model Truck {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  make              String
  model             String
  year              Int
  vin               String
  licensePlate      String
  odometer          Int      // Whole miles only (federal requirement)
  documentMetadata  Json?    // JSONB: registration number, insurance expiry, etc.
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  assignedRoutes     Route[]
  documents          Document[]
  maintenanceEvents  MaintenanceEvent[]
  scheduledServices  ScheduledService[]

  @@unique([tenantId, vin])
  @@index([tenantId])
}

model DriverInvitation {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @db.Uuid
  email              String
  firstName          String
  lastName           String
  licenseNumber      String?
  clerkInvitationId  String           @unique
  expiresAt          DateTime         @db.Timestamptz
  status             InvitationStatus @default(PENDING)
  acceptedAt         DateTime?        @db.Timestamptz
  userId             String?          @db.Uuid
  createdAt          DateTime         @default(now()) @db.Timestamptz
  updatedAt          DateTime         @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([clerkInvitationId])
}

model Route {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @db.Uuid
  driverId      String      @db.Uuid
  truckId       String      @db.Uuid
  origin        String
  destination   String
  scheduledDate DateTime    @db.Timestamptz
  status        RouteStatus @default(PLANNED)
  notes         String?
  completedAt   DateTime?   @db.Timestamptz
  createdAt     DateTime    @default(now()) @db.Timestamptz
  updatedAt     DateTime    @updatedAt @db.Timestamptz

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  driver    User       @relation(fields: [driverId], references: [id])
  truck     Truck      @relation(fields: [truckId], references: [id])
  documents Document[]

  @@index([tenantId])
  @@index([driverId])
  @@index([truckId])
  @@index([scheduledDate])
  @@index([status])
}

model Document {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  truckId     String?  @db.Uuid
  routeId     String?  @db.Uuid
  fileName    String
  s3Key       String
  contentType String
  sizeBytes   Int
  uploadedBy  String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  truck    Truck?  @relation(fields: [truckId], references: [id])
  route    Route?  @relation(fields: [routeId], references: [id])
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([routeId])
  @@index([uploadedBy])
}

model MaintenanceEvent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  truckId           String   @db.Uuid
  serviceType       String
  serviceDate       DateTime @db.Timestamptz
  odometerAtService Int
  cost              Decimal? @db.Decimal(10, 2)
  provider          String?
  notes             String?
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([serviceDate])
}

model ScheduledService {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  truckId          String    @db.Uuid
  serviceType      String
  intervalDays     Int?
  intervalMiles    Int?
  baselineDate     DateTime  @db.Timestamptz
  baselineOdometer Int
  notes            String?
  isCompleted      Boolean   @default(false)
  completedAt      DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  truck  Truck  @relation(fields: [truckId], references: [id])

  @@index([tenantId])
  @@index([truckId])
  @@index([isCompleted])
}
