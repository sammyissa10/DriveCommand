# Database
DATABASE_URL="postgresql://drivecommand_app:password@localhost:5432/drivecommand"

# Auth
AUTH_SECRET=change-this-to-a-random-32-char-string-in-production

# Google Maps (optional - enables address autocomplete in route forms)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App URL (used for generating links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
